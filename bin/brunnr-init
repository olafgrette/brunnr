#!/usr/bin/env bash
#
# brunnr-init — install the brunnr schema into a well directory.
#
# Installs AGENTS.md, procedures/, a CLAUDE.md mirror, and the Claude Code
# shims from this brunnr checkout into a target well, and seeds a fresh
# well skeleton (WELL.md, source/, wiki/index.md, wiki/log.md) on first run.
# Marks the well with a .brunnr.toml file (ownership + recorded mode).
#
# Usage:
#   brunnr-init [TARGET_DIR]        # default TARGET_DIR = current directory
#   brunnr-init --copy [TARGET]     # force copy mode
#   brunnr-init --symlink [TARGET]  # force symlink mode
#   brunnr-init --force [TARGET]    # overwrite a directory that isn't a brunnr well
#
# By default it symlinks (so kit updates propagate live). If the target
# filesystem can't create symlinks (e.g. an rclone Google Drive mount) it
# automatically falls back to copying. The chosen mode is recorded in
# .brunnr.toml and reused on re-init unless you pass --copy/--symlink.
# Refuses to overwrite a directory that isn't already a brunnr well
# (no .brunnr.toml) unless --force is given. Never touches source/, existing
# wiki/ pages, or an existing WELL.md.

set -euo pipefail

MODE=auto
FORCE=0
TARGET=""

while [ $# -gt 0 ]; do
  case "$1" in
    --copy)    MODE=copy ;;
    --symlink) MODE=symlink ;;
    --force)   FORCE=1 ;;
    -h|--help) awk 'NR==1{next} /^#/{sub(/^# ?/,""); print; next} {exit}' "$0"; exit 0 ;;
    -*)        echo "brunnr-init: unknown option: $1" >&2; exit 2 ;;
    *)         TARGET="$1" ;;
  esac
  shift
done

# Resolve the kit root (parent of the dir holding this script), following symlinks.
SELF="$0"
while [ -L "$SELF" ]; do SELF="$(readlink "$SELF")"; done
KIT="$(cd "$(dirname "$SELF")/.." && pwd)"

TARGET="${TARGET:-$PWD}"
mkdir -p "$TARGET"
TARGET="$(cd "$TARGET" && pwd)"

if [ "$TARGET" = "$KIT" ]; then
  echo "brunnr-init: refusing to install into the kit itself ($KIT)" >&2
  exit 2
fi

# Paths the installer overwrites (relative to TARGET); used by the ownership guard.
MANAGED=(AGENTS.md CLAUDE.md procedures)
for d in "$KIT"/shims/claude-code/*/; do [ -d "$d" ] && MANAGED+=(".claude/skills/$(basename "$d")"); done

toml_get() {  # toml_get KEY FILE -> unquoted value (empty if missing)
  [ -f "$2" ] || return 0
  sed -n 's/^'"$1"'[[:space:]]*=[[:space:]]*"\{0,1\}\([^"]*\)"\{0,1\}[[:space:]]*$/\1/p' "$2" | head -1
}

brunnr_owns() {  # may we overwrite path $1? (absent / symlink / brunnr-signed)
  local p="$1"
  [ ! -e "$p" ] && return 0
  [ -L "$p" ] && return 0
  [ -f "$p" ] && [ "$(head -1 "$p" 2>/dev/null)" = "# Wiki Schema" ] && return 0
  [ -d "$p" ] && { [ -f "$p/ingest.md" ] || [ -f "$p/SKILL.md" ]; } && return 0
  return 1
}

write_marker() {  # (re)write the .brunnr.toml ownership + mode marker
  local init_date; init_date="$(toml_get initialized "$TARGET/.brunnr.toml")"
  [ -n "$init_date" ] || init_date="$(date +%F)"
  cat > "$TARGET/.brunnr.toml" <<EOF
# Managed by brunnr-init — marks this directory as a brunnr well. Do not edit.
install-mode = "$MODE"
kit = "$KIT"
initialized = "$init_date"
updated = "$(date +%F)"
EOF
}

# Ownership guard: don't clobber a directory that isn't already a brunnr well
# and holds foreign files where we'd install (unless --force).
if [ "$FORCE" != 1 ] && [ ! -e "$TARGET/.brunnr.toml" ]; then
  conflicts=()
  for rel in "${MANAGED[@]}"; do brunnr_owns "$TARGET/$rel" || conflicts+=("$rel"); done
  if [ "${#conflicts[@]}" -gt 0 ]; then
    echo "brunnr-init: $TARGET is not a brunnr well and has files that would be overwritten:" >&2
    printf '  %s\n' "${conflicts[@]}" >&2
    echo "Refusing. Re-run with --force to overwrite, or choose an empty / brunnr directory." >&2
    exit 3
  fi
fi

# Resolve install mode: explicit flag > mode recorded in .brunnr.toml > auto-probe.
if [ "$MODE" = auto ]; then
  recorded="$(toml_get install-mode "$TARGET/.brunnr.toml")"
  case "$recorded" in copy|symlink) MODE="$recorded" ;; esac
fi

symlink_ok() {  # does TARGET's filesystem support symlinks?
  local p="$TARGET/.wk-symlink-probe.$$"
  if ln -s . "$p" 2>/dev/null; then rm -f "$p"; return 0; fi
  return 1
}

if [ "$MODE" = auto ]; then
  if symlink_ok; then MODE=symlink; else MODE=copy; fi
elif [ "$MODE" = symlink ] && ! symlink_ok; then
  echo "brunnr-init: symlink mode unavailable on this filesystem; using copy." >&2
  MODE=copy
fi

place() {  # place SRC DEST — refresh DEST from kit SRC (symlink or copy)
  local src="$1" dest="$2"
  rm -rf "$dest"
  if [ "$MODE" = symlink ]; then ln -s "$src" "$dest"; else cp -R "$src" "$dest"; fi
}

seed() {  # seed TEMPLATE DEST — render templates/TEMPLATE into DEST if absent ({{DATE}} -> today)
  local tpl="$KIT/templates/$1" dest="$2"
  [ -e "$dest" ] && return 0
  sed "s/{{DATE}}/$(date +%F)/g" "$tpl" > "$dest"
  echo "  + ${dest#"$TARGET"/}"
}

echo "brunnr-init: installing into $TARGET  (mode: $MODE, kit: $KIT)"

# --- Schema owned by the kit (always refreshed) ---
place "$KIT/well-AGENTS.md" "$TARGET/AGENTS.md"
place "$KIT/procedures" "$TARGET/procedures"

# CLAUDE.md mirrors AGENTS.md so Claude Code picks up the schema.
rm -f "$TARGET/CLAUDE.md"
if [ "$MODE" = symlink ]; then ln -s AGENTS.md "$TARGET/CLAUDE.md"; else cp "$KIT/well-AGENTS.md" "$TARGET/CLAUDE.md"; fi

# Claude Code shims — each skill delegates to procedures/.
mkdir -p "$TARGET/.claude/skills"
for d in "$KIT"/shims/claude-code/*/; do
  [ -d "$d" ] || continue
  place "${d%/}" "$TARGET/.claude/skills/$(basename "$d")"
done

# --- Well-local files: seeded from templates/ on first run, never overwritten ---
mkdir -p "$TARGET/source" "$TARGET/wiki" "$TARGET/inbox"
seed WELL.md "$TARGET/WELL.md"
seed index.md "$TARGET/wiki/index.md"
seed log.md   "$TARGET/wiki/log.md"

# Mark the well as brunnr-owned and record the resolved mode.
write_marker

# Make the `brunnr` helper available as a PATH command (machine-level). It points at
# the kit so updates propagate, and stays on the kit's filesystem — never inside the
# well, which may sit on a mount (e.g. rclone gdrive) that refuses execve. The well
# is resolved from $PWD, so one command serves every well. Best-effort: a well still
# works without it; agents would just invoke "$KIT/bin/brunnr" by path.
HELPER_LINK="$HOME/.local/bin/brunnr"
if [ -e "$HELPER_LINK" ] && [ ! -L "$HELPER_LINK" ]; then
  echo "brunnr-init: $HELPER_LINK exists and isn't a brunnr symlink — leaving it. Run brunnr via $KIT/bin/brunnr." >&2
elif mkdir -p "$HOME/.local/bin" 2>/dev/null && ln -sfn "$KIT/bin/brunnr" "$HELPER_LINK" 2>/dev/null; then
  echo "  linked $HELPER_LINK -> $KIT/bin/brunnr"
  case ":$PATH:" in *":$HOME/.local/bin:"*) : ;; *) echo "  note: add ~/.local/bin to PATH to use the 'brunnr' command." >&2 ;; esac
else
  echo "brunnr-init: couldn't link brunnr into ~/.local/bin; run it as $KIT/bin/brunnr." >&2
fi

echo "brunnr-init: done (mode: $MODE)."
if [ "$MODE" = copy ]; then
  echo "  note: copy mode — re-run brunnr-init after updating the kit to refresh this well."
fi
